// Selah — Modo Producción
// Adaptado de esquema_base_de_datos.txt (ver plan aprobado para el detalle de cada cambio).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// CATALOGOS
// ============================================================

model Categoria {
  id_categoria Int    @id @default(autoincrement()) @db.SmallInt
  nombre       String @unique // Pulsera, Anillo, Arete

  productos Producto[]

  @@map("categorias")
}

// Escalera de precios. costo_max = tope de costo del nivel (regla margen >= 30%).
model Clasificacion {
  id_clasif     String   @id @db.VarChar(2) // C, B, A, A3, A2, A1, M
  descripcion   String?
  precio_tarifa Decimal  @default(0) @db.Decimal(12, 2)
  costo_max     Decimal? @db.Decimal(12, 2) // NULL = sin tope (M)

  productos Producto[]

  @@map("clasificaciones")
}

model MetodoPago {
  id_metodo Int    @id @default(autoincrement()) @db.SmallInt
  nombre    String @unique // Efectivo, Tarjeta, Deposito, Transferencia

  ventas  Venta[]
  compras Compra[]
  gastos  Gasto[]

  @@map("metodos_pago")
}

model TipoGasto {
  id_tipo_gasto Int    @id @default(autoincrement()) @db.SmallInt
  nombre        String @unique

  gastos Gasto[]

  @@map("tipos_gasto")
}

// NUEVO: tipos de hilo disponibles para la calculadora, con su costo. Editable en Configuración.
model TipoHilo {
  id_tipo_hilo Int     @id @default(autoincrement()) @db.SmallInt
  nombre       String  @unique // Nylon, Negro...
  costo        Decimal @db.Decimal(12, 2)

  productos Producto[]

  @@map("tipos_hilo")
}

// NUEVO: fila única con los costos fijos editables desde Configuración.
model Configuracion {
  id                  Int     @id @default(1)
  costo_mano_obra     Decimal @default(20) @db.Decimal(12, 2)
  costo_empaque       Decimal @default(10) @db.Decimal(12, 2)
  costo_pago_hermana  Decimal @default(20) @db.Decimal(12, 2)
  margen_objetivo     Decimal @default(0.30) @db.Decimal(5, 4)

  @@map("configuracion")
}

// ============================================================
// ENTIDADES BASE
// ============================================================

model Proveedor {
  id_proveedor Int     @id @default(autoincrement()) @db.SmallInt
  nombre       String
  telefono     String?
  direccion    String?

  materiales Material[]
  compras    Compra[]

  @@map("proveedores")
}

model Empleado {
  id_empleado Int     @id @default(autoincrement()) @db.SmallInt
  nombre      String
  apellido    String?
  activo      Boolean @default(true)

  compras     Compra[]
  gastos      Gasto[]
  produccion  Produccion[]

  @@map("empleados")
}

model Cliente {
  id_cliente    Int      @id @default(autoincrement())
  nombre        String
  apellido      String?
  edad          Int?     @db.SmallInt
  correo        String?
  telefono      String?
  direccion     String?
  es_revendedor Boolean  @default(false)
  preferente    Boolean  @default(false)
  acepta_promos Boolean  @default(false)
  creado_en     DateTime @default(now()) @db.Timestamptz()

  ventas Venta[]

  @@map("clientes")
}

// ============================================================
// MATERIALES
// costo_unitario se calcula en la aplicación (costo_tira / piezas_por_tira)
// al crear/editar el material — Prisma no soporta columnas GENERATED STORED en su DSL.
// ============================================================

model Material {
  id_material      String   @id // código asignado a mano, ej. "PERLA-6MM-BLANCA"
  nombre           String?  // etiqueta corta opcional, solo para mostrar
  descripcion      String?
  largo_mm         Decimal? @db.Decimal(10, 2)
  ancho_mm         Decimal? @db.Decimal(10, 2)
  costo_tira       Decimal  @db.Decimal(12, 2)
  piezas_por_tira  Decimal? @db.Decimal(12, 2)
  costo_unitario   Decimal? @db.Decimal(12, 4) // costo_tira / piezas_por_tira
  stock_piezas     Decimal  @default(0) @db.Decimal(12, 2)
  id_proveedor     Int?     @db.SmallInt

  proveedor           Proveedor?         @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: SetNull)
  producto_materiales ProductoMaterial[]
  compra_detalle      CompraDetalle[]

  @@index([id_proveedor])
  @@map("materiales")
}

// ============================================================
// PRODUCTOS (diseños) + RECETA (Bill of Materials)
// ============================================================

model Producto {
  id_producto     Int      @id @default(autoincrement())
  nombre          String
  id_categoria    Int?     @db.SmallInt
  id_clasif       String?  @db.VarChar(2)
  id_tipo_hilo    Int?     @db.SmallInt
  precio          Decimal  @default(0) @db.Decimal(12, 2)
  costo_mano_obra Decimal  @default(0) @db.Decimal(12, 2) // fijo congelado (mano de obra + empaque + pago hermana)
  stock_piezas    Decimal  @default(0) @db.Decimal(12, 2)
  activo          Boolean  @default(true)

  categoria      Categoria?         @relation(fields: [id_categoria], references: [id_categoria], onDelete: Restrict)
  clasificacion  Clasificacion?     @relation(fields: [id_clasif], references: [id_clasif], onDelete: Restrict)
  tipo_hilo      TipoHilo?          @relation(fields: [id_tipo_hilo], references: [id_tipo_hilo], onDelete: SetNull)
  materiales     ProductoMaterial[]
  producciones   Produccion[]
  venta_detalle  VentaDetalle[]

  @@index([id_categoria])
  @@index([id_clasif])
  @@map("productos")
}

// RECETA: habilita todo el costeo.
model ProductoMaterial {
  id_producto Int
  id_material String
  cantidad    Decimal @db.Decimal(10, 2) // piezas por producto

  producto Producto @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade)
  material Material @relation(fields: [id_material], references: [id_material], onDelete: Restrict)

  @@id([id_producto, id_material])
  @@index([id_material])
  @@map("producto_materiales")
}

// ============================================================
// COMPRAS (material) + GASTOS (no inventariable)
// ============================================================

model Compra {
  id_compra    Int      @id @default(autoincrement())
  ticket       String?
  fecha        DateTime @default(now()) @db.Date
  id_proveedor Int?     @db.SmallInt
  id_metodo    Int?     @db.SmallInt
  id_empleado  Int?     @db.SmallInt
  total        Decimal  @default(0) @db.Decimal(12, 2)

  proveedor Proveedor?      @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: SetNull)
  metodo    MetodoPago?     @relation(fields: [id_metodo], references: [id_metodo], onDelete: SetNull)
  empleado  Empleado?       @relation(fields: [id_empleado], references: [id_empleado], onDelete: SetNull)
  detalle   CompraDetalle[]

  @@map("compras")
}

model CompraDetalle {
  id_compra   Int
  id_material String
  cantidad    Decimal @db.Decimal(12, 2)
  costo_unit  Decimal @db.Decimal(12, 4)

  compra   Compra   @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade)
  material Material @relation(fields: [id_material], references: [id_material], onDelete: Restrict)

  @@id([id_compra, id_material])
  @@index([id_material])
  @@map("compra_detalle")
}

model Gasto {
  id_gasto      Int      @id @default(autoincrement())
  fecha         DateTime @default(now()) @db.Date
  id_tipo_gasto Int?     @db.SmallInt
  concepto      String?
  cantidad      Decimal  @default(1) @db.Decimal(12, 2)
  monto         Decimal  @db.Decimal(12, 2)
  id_metodo     Int?     @db.SmallInt
  id_empleado   Int?     @db.SmallInt

  tipo_gasto TipoGasto?  @relation(fields: [id_tipo_gasto], references: [id_tipo_gasto], onDelete: Restrict)
  metodo     MetodoPago? @relation(fields: [id_metodo], references: [id_metodo], onDelete: SetNull)
  empleado   Empleado?   @relation(fields: [id_empleado], references: [id_empleado], onDelete: SetNull)

  @@index([fecha])
  @@index([id_tipo_gasto])
  @@map("gastos")
}

// ============================================================
// VENTAS (detalle enlaza producto y congela costo/precio)
// ============================================================

model Venta {
  id_venta      Int      @id @default(autoincrement())
  fecha_hora    DateTime @default(now()) @db.Timestamptz()
  id_cliente    Int?
  tipo_venta    String   @default("Contado")
  id_metodo     Int?     @db.SmallInt
  descuento     Decimal  @default(0) @db.Decimal(12, 2)
  total         Decimal  @default(0) @db.Decimal(12, 2)
  pago_recibido Decimal  @default(0) @db.Decimal(12, 2)

  cliente Cliente?       @relation(fields: [id_cliente], references: [id_cliente], onDelete: SetNull)
  metodo  MetodoPago?    @relation(fields: [id_metodo], references: [id_metodo], onDelete: SetNull)
  detalle VentaDetalle[]

  @@index([id_cliente])
  @@index([fecha_hora])
  @@map("ventas")
}

model VentaDetalle {
  id_venta        Int
  linea           Int     @db.SmallInt
  id_producto     Int?
  cantidad        Int
  precio_unit     Decimal @db.Decimal(12, 2) // congelado
  costo_unit_snap Decimal @default(0) @db.Decimal(12, 4) // congelado al vender

  venta    Venta     @relation(fields: [id_venta], references: [id_venta], onDelete: Cascade)
  producto Producto? @relation(fields: [id_producto], references: [id_producto], onDelete: SetNull)

  @@id([id_venta, linea])
  @@index([id_producto])
  @@map("venta_detalle")
}

// ============================================================
// PRODUCCION (bajo pedido + stock)
// ============================================================

model Produccion {
  id_produccion Int      @id @default(autoincrement())
  fecha         DateTime @default(now()) @db.Date
  id_producto   Int
  cantidad      Int
  id_empleado   Int?     @db.SmallInt
  para_stock    Boolean  @default(true)
  costo_mo_lote Decimal  @default(0) @db.Decimal(12, 2)

  producto Producto  @relation(fields: [id_producto], references: [id_producto], onDelete: Restrict)
  empleado Empleado? @relation(fields: [id_empleado], references: [id_empleado], onDelete: SetNull)

  @@index([id_producto])
  @@map("produccion")
}
